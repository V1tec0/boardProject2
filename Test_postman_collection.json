		{
			"name": "Login",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.sendRequest({\r",
							"    url: 'http://localhost:8000/api/csrf/',\r",
							"    method: 'GET'\r",
							"}, (err, res) => {\r",
							"    if(err) {\r",
							"        console.log(err)\r",
							"    } else {\r",
							"        const setCookieHeader = res.headers.get('Set-Cookie');\r",
							"        console.log('Set-Cookie header:', setCookieHeader);\r",
							"\r",
							"        // Парсинг куки для получения csrftoken и других данных\r",
							"        const cookies = {};\r",
							"        if (setCookieHeader) {\r",
							"            setCookieHeader.split(';').forEach(cookie => {\r",
							"                const [name, value] = cookie.split('=');\r",
							"                if (name && value) {\r",
							"                    cookies[name.trim()] = value.trim();\r",
							"                }\r",
							"            });\r",
							"        }\r",
							"\r",
							"        // Получение csrftoken\r",
							"        const sessionid = cookies['sessionid'];\r",
							"\r",
							"        pm.environment.set('X-CSRFToken', res.headers.get('X-CSRFToken'))\r",
							"        pm.environment.set('CSRFToken', pm.cookies.get('csrftoken'))\r",
							"        pm.environment.set('sessionid', sessionid)\r",
							"    }\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.environment.set('sessionid', pm.cookies.get('sessionid'))\r",
							"\r",
							"pm.test(\"Response status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"\r",
							"pm.test(\"Response time is less than 200ms\", function () {\r",
							"  pm.expect(pm.response.responseTime).to.be.below(200);\r",
							"});\r",
							"\r",
							"\r",
							"pm.test(\"Response schema contains required fields\", function () {\r",
							"    const responseData = pm.response.json();\r",
							"    \r",
							"    pm.expect(responseData).to.be.an('object');\r",
							"    pm.expect(responseData).to.have.property('detail');\r",
							"});\r",
							"\r",
							"\r",
							"pm.test(\"Ensure the 'detail' field is a non-empty string\", function () {\r",
							"  const responseData = pm.response.json();\r",
							"  \r",
							"  pm.expect(responseData).to.be.an('object');\r",
							"  pm.expect(responseData.detail).to.be.a('string').and.to.have.lengthOf.at.least(1, \"Value should not be empty\");\r",
							"});\r",
							"\r",
							"\r",
							"pm.test(\"Content-Type header is application/json\", function () {\r",
							"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
							"});\r",
							"\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
